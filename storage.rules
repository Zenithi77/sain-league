rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Public read for all stored assets
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only authenticated users can upload player images
    match /players/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Only authenticated users can upload coach images
    match /coaches/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Only authenticated users can upload sponsor logos
    match /sponsors/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Only authenticated users can upload news images
    match /news-images/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Only authenticated users can upload avatar body images (ImageTo3D)
    match /avatars/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}